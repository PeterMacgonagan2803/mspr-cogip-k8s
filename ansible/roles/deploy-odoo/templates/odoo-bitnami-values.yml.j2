# Valeurs Helm — chart bitnami/odoo (PoC MSPR COGIP / Tesker)
# Ingress Traefik (K3s) + certificat TLS autosigné généré par le chart (selfSigned)

global:
  defaultStorageClass: "{{ nfs_storage_class | default('nfs-client') }}"
  security:
    # Images bitnamilegacy (Docker Hub) : le chart refuse les depots non « bitnami/ » sans ce flag.
    allowInsecureImages: true

# bitnami/odoo sur Docker Hub est vide ; les tags du chart restent sur bitnamilegacy.
image:
  registry: docker.io
  repository: bitnamilegacy/odoo
  tag: 18.0.20250805-debian-12-r8

odooEmail: "{{ odoo_email | default('admin@cogip.local') }}"
odooPassword: "{{ odoo_bitnami_admin_password }}"

postgresql:
  enabled: true
  auth:
    password: "{{ odoo_bitnami_pg_password }}"
  image:
    registry: docker.io
    repository: bitnamilegacy/postgresql
    tag: 17.5.0-debian-12-r20
  primary:
    persistence:
      enabled: true
      storageClass: "{{ nfs_storage_class | default('nfs-client') }}"
      size: 5Gi

persistence:
  enabled: true
  storageClass: "{{ nfs_storage_class | default('nfs-client') }}"
  size: 5Gi

replicaCount: 1

# LoadBalancer reste <pending> sur K3s sans CCM ; l'Ingress Traefik suffit.
service:
  type: ClusterIP

ingress:
  enabled: true
  ingressClassName: traefik
  hostname: "{{ odoo_domain | default('odoo.local') }}"
  path: /
  pathType: Prefix
  tls: true
  selfSigned: true
  annotations:
    # web (80) + websecure (443) : sans « web », http://odoo.local ne matche aucune route Traefik.
    traefik.ingress.kubernetes.io/router.entrypoints: web,websecure

networkPolicy:
  enabled: false

resources:
  requests:
    cpu: "{{ odoo_cpu_request | default('500m') }}"
    memory: "{{ odoo_memory_request | default('512Mi') }}"
  limits:
    cpu: "{{ odoo_cpu_limit | default('1') }}"
    memory: "{{ odoo_memory_limit | default('1Gi') }}"
